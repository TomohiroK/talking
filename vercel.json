{
  "version": 2,
  "crons": [
    { "path": "/api/generate-trends", "schedule": "0 0 * * *" }
  ],
  "rewrites": [
    { "source": "/lp/en", "destination": "/api/lp?lang=en" },
    { "source": "/lp", "destination": "/api/lp" },
    { "source": "/", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "static/**"
    },
    "api/lp.js": {
      "includeFiles": "static/**"
    }
  }
}
